<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
    <file source-language="en" datatype="plaintext" original="EXT:translate/Resources/Private/Language/locallang.xlf">
        <body>
            <trans-unit id="button.translate">
                <source>Translate</source>
            </trans-unit>
            <trans-unit id="modal.title">
                <source>Translate record</source>
            </trans-unit>
            <trans-unit id="modal.provider.label">
                <source>Translation provider</source>
            </trans-unit>
            <trans-unit id="modal.provider.deepl">
                <source>DeepL</source>
            </trans-unit>
            <trans-unit id="modal.provider.openai">
                <source>OpenAI</source>
            </trans-unit>
            <trans-unit id="modal.targetLanguage.label">
                <source>Target language</source>
            </trans-unit>
            <trans-unit id="modal.targetLanguage.placeholder">
                <source>e.g. DE, EN, FR, ES</source>
            </trans-unit>
            <trans-unit id="modal.sourceLanguage.label">
                <source>Source language (optional)</source>
            </trans-unit>
            <trans-unit id="modal.sourceLanguage.placeholder">
                <source>Auto-detect</source>
            </trans-unit>
            <trans-unit id="modal.submit">
                <source>Translate now</source>
            </trans-unit>
            <trans-unit id="modal.cancel">
                <source>Cancel</source>
            </trans-unit>
            <trans-unit id="notice.translating">
                <source>Translating…</source>
            </trans-unit>
            <trans-unit id="notice.success">
                <source>Translation applied successfully.</source>
            </trans-unit>
            <trans-unit id="notice.error">
                <source>Translation failed: </source>
            </trans-unit>
            <trans-unit id="notice.noFields">
                <source>No translatable fields found for this record.</source>
            </trans-unit>
        </body>
    </file>
</xliff>
